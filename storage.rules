// =====================================================
// Firebase Storage biztonsági szabályok – Travelpont Portal
// Verzió: 1.0.0
//
// Logika (az aktivbalaton-portal mintáját követve):
//   - Csak bejelentkezett felhasználók tölthetnek fel
//   - Max fájlméret: 5MB
//   - Csak képfájlok engedélyezettek
//   - Feltöltés csak a saját (uid) mappájába, olvasás bármely bejelentkezettnek
// =====================================================

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ---- Ajánlat kiemelt képek ----
    match /ajanlatok/{userId}/{fileName} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // ---- Úticél kiemelt képek ----
    match /uticelok/{userId}/{fileName} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // ---- Minden más tiltva ----
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
